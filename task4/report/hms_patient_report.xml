<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <template id="hms_patient_report_template">
    <t t-call="web.html_container">
      <t t-foreach="docs" t-as="doc">
        <t t-call="web.external_layout">
          <div class="page">

            <!-- Header -->
            <div class="row mb-4">
              <div class="col-8">
                <h2 style="color: red; font-weight: bold;">Patient Status Report</h2>
              </div>
              <div class="col-4 text-end">
                <t t-if="doc.image">
                  <img t-att-src="image_data_uri(doc.image)"
                       style="max-height:120px; max-width:120px;"/>
                </t>
              </div>
            </div>

            <!-- Patient Info -->
            <div class="row">
              <div class="col-6">
                <p><strong>Name:</strong>
                  <t t-out="doc.first_name"/> <t t-out="doc.last_name"/>
                </p>
                <p><strong>Age:</strong> <t t-out="doc.age"/></p>
                <p><strong>Department:</strong>
                  <t t-out="doc.department_id.name or 'N/A'"/>
                </p>
                <p><strong>Doctors:</strong>
                  <t t-out="', '.join(doc.doctor_ids.mapped(lambda d: d.first_name + ' ' + d.last_name)) or 'N/A'"/>
                </p>
              </div>
              <div class="col-6">
                <p><strong>Birth date:</strong>
                  <t t-out="doc.birth_date"/>
                </p>
                <p><strong>PCR:</strong> <t t-out="doc.cr_ratio"/></p>
                <p><strong>Blood Type:</strong>
                  <t t-out="doc.blood_type or 'N/A'"/>
                </p>
                <p><strong>Email:</strong>
                  <t t-out="doc.email or 'N/A'"/>
                </p>
              </div>
            </div>

            <!-- Log History -->
            <div class="row mt-4">
              <div class="col-12 text-center">
                <h4 style="color: red;">Log History</h4>
              </div>
            </div>
            <table class="table table-bordered">
              <thead style="background-color: #1F88E5; color: white;">
                <tr>
                  <th>User</th>
                  <th>Date</th>
                  <th>Info</th>
                </tr>
              </thead>
              <tbody>
                <t t-foreach="doc.log_ids" t-as="log">
                  <tr style="background-color: #D6E4F7;">
                    <td><t t-out="log.created_by.name"/></td>
                    <td><t t-out="log.date"/></td>
                    <td><t t-out="log.description"/></td>
                  </tr>
                </t>
              </tbody>
            </table>

          </div>
        </t>
      </t>
    </t>
  </template>
</odoo>
