<?xml version="1.0" encoding="utf-8"?>
<odoo>

=
  <record id="view_hms_patient_list" model="ir.ui.view">
      <field name="name">hms.patient.list</field>
      <field name="model">hms.patient</field>
      <field name="arch" type="xml">
          <list string="Patients">
              <field name="first_name"/>
              <field name="last_name"/>
              <field name="birth_date"/>
              <field name="age"/>
              <field name="blood_type"/>
              <field name="pcr"/>
          </list>
      </field>
  </record>

->
  <record id="view_hms_patient_form" model="ir.ui.view">
      <field name="name">hms.patient.form</field>
      <field name="model">hms.patient</field>
      <field name="arch" type="xml">
          <form string="Patient">
              <sheet>

                  <field name="image" widget="image"
                          class="oe_avatar" options="{'size': [128, 128]}"/>


                  <div class="oe_title">
                      <label for="first_name" string="Patient Name"/>
                      <h1>
                          <field name="first_name" placeholder="First Name"/>
                          <field name="last_name"  placeholder="Last Name"/>
                      </h1>
                  </div>


                  <group>
                      <group string="Personal Info">
                          <field name="birth_date"/>
                          <field name="age"/>
                          <field name="address"/>
                      </group>
                      <group string="Medical Info">
                          <field name="blood_type"/>
                          <field name="cr_ratio"/>
                          <field name="pcr"/>
                      </group>
                  </group>

                  <group string="Medical History">
                      <field name="history" nolabel="1"/>
                  </group>
              </sheet>
          </form>
      </field>
  </record>


  <record id="action_hms_patient" model="ir.actions.act_window">
      <field name="name">Patients</field>
      <field name="res_model">hms.patient</field>
      <field name="view_mode">list,form</field>
  </record>


  <menuitem
      id="menu_hms_root"
      name="HMS"
      sequence="10"/>


  <menuitem
      id="menu_hms_patients"
      name="Patients"
      parent="menu_hms_root"
      action="action_hms_patient"
      sequence="10"/>

</odoo>
